APP_ENV=local
APP_NAME=Garun Workspace
PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=info
DATABASE_URL=postgresql://garun:local_only_change_me@localhost:5432/garun_workspace
REDIS_URL=redis://:local_only_change_me@localhost:6379
BETTER_AUTH_SECRET=local-only-change-me-at-least-32-characters
AUTH_COOKIE_PREFIX=garun
INVITATION_TTL_HOURS=72
MAGIC_LINK_TTL_SECONDS=900
# Generate a unique local value with the command documented in README.
OUTBOX_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
FILE_MAX_BYTES=104857600
WORKSPACE_QUOTA_BYTES=10737418240
DELETED_FILE_GRACE_DAYS=30
TECHNICAL_LOG_RETENTION_DAYS=90
STORAGE_ENDPOINT=http://127.0.0.1:9000
STORAGE_PUBLIC_ENDPOINT=http://127.0.0.1:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=garun-private
STORAGE_ACCESS_KEY=garun_local
STORAGE_SECRET_KEY=local_only_change_me
STORAGE_FORCE_PATH_STYLE=true
STORAGE_UPLOAD_TTL_SECONDS=900
STORAGE_DOWNLOAD_TTL_SECONDS=60
INCOMPLETE_UPLOAD_RETENTION_HOURS=24
