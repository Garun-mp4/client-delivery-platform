{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "transit": {
      "dependsOn": ["^transit"]
    },
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "APP_ENV",
        "APP_NAME",
        "DATABASE_URL",
        "DELETED_FILE_GRACE_DAYS",
        "FILE_MAX_BYTES",
        "PUBLIC_APP_URL",
        "BETTER_AUTH_SECRET",
        "AUTH_COOKIE_PREFIX",
        "INVITATION_TTL_HOURS",
        "INCOMPLETE_UPLOAD_RETENTION_HOURS",
        "MAGIC_LINK_TTL_SECONDS",
        "OUTBOX_ENCRYPTION_KEY",
        "REDIS_URL",
        "STORAGE_ACCESS_KEY",
        "STORAGE_BUCKET",
        "STORAGE_DOWNLOAD_TTL_SECONDS",
        "STORAGE_ENDPOINT",
        "STORAGE_FORCE_PATH_STYLE",
        "STORAGE_PUBLIC_ENDPOINT",
        "STORAGE_REGION",
        "STORAGE_SECRET_KEY",
        "STORAGE_UPLOAD_TTL_SECONDS",
        "TECHNICAL_LOG_RETENTION_DAYS",
        "WORKSPACE_QUOTA_BYTES"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "env": [
        "APP_ENV",
        "APP_NAME",
        "DATABASE_URL",
        "DELETED_FILE_GRACE_DAYS",
        "FILE_MAX_BYTES",
        "LOG_LEVEL",
        "PUBLIC_APP_URL",
        "BETTER_AUTH_SECRET",
        "AUTH_COOKIE_PREFIX",
        "INVITATION_TTL_HOURS",
        "INCOMPLETE_UPLOAD_RETENTION_HOURS",
        "MAGIC_LINK_TTL_SECONDS",
        "OUTBOX_ENCRYPTION_KEY",
        "EMAIL_FROM",
        "SMTP_HOST",
        "SMTP_PORT",
        "SMTP_SECURE",
        "REDIS_URL",
        "SCANNER_HOST",
        "SCANNER_PORT",
        "SCANNER_REQUIRED",
        "STORAGE_ACCESS_KEY",
        "STORAGE_BUCKET",
        "STORAGE_DOWNLOAD_TTL_SECONDS",
        "STORAGE_ENDPOINT",
        "STORAGE_FORCE_PATH_STYLE",
        "STORAGE_PUBLIC_ENDPOINT",
        "STORAGE_REGION",
        "STORAGE_SECRET_KEY",
        "STORAGE_UPLOAD_TTL_SECONDS",
        "TECHNICAL_LOG_RETENTION_DAYS",
        "WORKER_HOST",
        "WORKER_PORT",
        "WORKSPACE_QUOTA_BYTES"
      ],
      "persistent": true
    },
    "format": {
      "cache": false
    },
    "format:check": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "test:integration": {
      "cache": false,
      "env": [
        "TEST_DATABASE_URL",
        "TEST_MAILPIT_URL",
        "TEST_MINIO_ACCESS_KEY",
        "TEST_MINIO_ENDPOINT",
        "TEST_MINIO_SECRET_KEY",
        "TEST_REDIS_URL",
        "TEST_SCANNER_HOST",
        "TEST_SCANNER_PORT"
      ]
    },
    "test:e2e": {
      "cache": false,
      "env": [
        "CI",
        "WEB_BASE_URL",
        "WEB_SERVER_PORT",
        "DATABASE_URL",
        "REDIS_URL",
        "BETTER_AUTH_SECRET",
        "INCOMPLETE_UPLOAD_RETENTION_HOURS",
        "OUTBOX_ENCRYPTION_KEY",
        "EMAIL_FROM",
        "SMTP_HOST",
        "SMTP_PORT",
        "SMTP_SECURE",
        "SCANNER_HOST",
        "SCANNER_PORT",
        "SCANNER_REQUIRED",
        "STORAGE_ACCESS_KEY",
        "STORAGE_BUCKET",
        "STORAGE_DOWNLOAD_TTL_SECONDS",
        "STORAGE_ENDPOINT",
        "STORAGE_FORCE_PATH_STYLE",
        "STORAGE_PUBLIC_ENDPOINT",
        "STORAGE_REGION",
        "STORAGE_SECRET_KEY",
        "STORAGE_UPLOAD_TTL_SECONDS",
        "E2E_OWNER_EMAIL",
        "E2E_OWNER_PASSWORD"
      ]
    },
    "db:generate": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "db:migrate": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "smoke": {
      "cache": false,
      "env": ["WEB_BASE_URL", "WORKER_BASE_URL"]
    },
    "verify:artifact": {
      "dependsOn": ["build"],
      "outputs": []
    }
  }
}
