{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "transit": {
      "dependsOn": ["^transit"]
    },
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "APP_ENV",
        "APP_NAME",
        "DELETED_FILE_GRACE_DAYS",
        "FILE_MAX_BYTES",
        "PUBLIC_APP_URL",
        "TECHNICAL_LOG_RETENTION_DAYS",
        "WORKSPACE_QUOTA_BYTES"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "env": [
        "APP_ENV",
        "APP_NAME",
        "DATABASE_URL",
        "DELETED_FILE_GRACE_DAYS",
        "FILE_MAX_BYTES",
        "LOG_LEVEL",
        "PUBLIC_APP_URL",
        "REDIS_URL",
        "TECHNICAL_LOG_RETENTION_DAYS",
        "WORKER_HOST",
        "WORKER_PORT",
        "WORKSPACE_QUOTA_BYTES"
      ],
      "persistent": true
    },
    "format": {
      "cache": false
    },
    "format:check": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "test:integration": {
      "cache": false,
      "env": [
        "TEST_DATABASE_URL",
        "TEST_MAILPIT_URL",
        "TEST_MINIO_ACCESS_KEY",
        "TEST_MINIO_ENDPOINT",
        "TEST_MINIO_SECRET_KEY",
        "TEST_REDIS_URL"
      ]
    },
    "test:e2e": {
      "cache": false,
      "env": ["CI", "WEB_BASE_URL"]
    },
    "db:generate": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "db:migrate": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "smoke": {
      "cache": false,
      "env": ["WEB_BASE_URL", "WORKER_BASE_URL"]
    }
  }
}
