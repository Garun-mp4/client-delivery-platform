{
  "name": "garun-workspace",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.22.0 <25"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "verify:artifacts": "turbo run verify:artifact",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "db:generate": "turbo run db:generate --filter=@garun/db",
    "db:migrate": "turbo run db:migrate --filter=@garun/db",
    "smoke": "turbo run smoke"
  },
  "devDependencies": {
    "turbo": "2.10.5"
  }
}
